# .npmignore — controls what is excluded from the npm tarball.
# The `files` whitelist in package.json takes precedence, but this
# provides an additional safety net against accidental inclusion.

# Source code (only compiled dist/ is shipped)
src/
tests/
tsconfig.json
vitest.config.ts

# Development files
node_modules/
.git/
.github/
*.log
*.lock

# Test artifacts
coverage/
.nyc_output/

# Content directories not part of the npm package
Skills/
plugins/
